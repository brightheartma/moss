    "gen:abis": "wagmi generate"
  },
  "dependencies": {
    "@themoss/core": "workspace:*",
    "viem": "^2.54.3"
  },
  "devDependencies": {
    "@wagmi/cli": "^2.10.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.0",
    "vite": "~7.3.6",
    "vitest": "^4.1.10",
    "@themoss/simulator": "workspace:*"
  }
}
