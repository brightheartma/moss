{
  "name": "@themoss/protocol-kuru",
  "version": "0.1.0",
  "description": "Moss protocol adapter for Kuru — Monad-native on-chain CLOB DEX",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "update:abis": "tsx scripts/update-abis.ts",
    "gen:abis": "tsx scripts/gen-abis.ts"
  },
  "dependencies": {
    "@themoss/core": "workspace:*",
    "viem": "^2.54.3",
    "@themoss/erc": "workspace:*",
    "@themoss/system": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~6.0.0",
    "vite": "~7.3.6",
    "vitest": "^4.1.10",
    "tsx": "^4.19.0",
    "@themoss/simulator": "workspace:*"
  }
}
